<?xml version="1.0" ?>
<robot name="amir_mecanum3" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- メカナムローバー URDF
       mecanum3.gazebo (gz_ros2_control-system) と
       mecanum3_ros2_control.xacro (MecanumSystem) を含む -->
  <xacro:include filename="$(find mecanumrover_description)/urdf/mecanum3.xacro"/>

  <!-- AMIR アーム リンク/ジョイント -->
  <xacro:include filename="$(find amir_description)/urdf/amir_for_rover.xacro"/>

  <!-- ローバーとアームの固定接続 -->
  <joint name="base_fixed" type="fixed">
    <origin xyz="0.0 0.0 0.413" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link0_1"/>
  </joint>

  <!-- AMIR アーム Ignition Gazebo 用 ros2_control
       gz_ros2_control-system プラグインが URDF 内の全 <ros2_control> タグを
       読み込み GazeboSimSystem としてシミュレーションする -->
  <ros2_control name="AmirGazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="Joint_1">
      <command_interface name="position">
        <param name="min">-2.96706</param>
        <param name="max">2.96706</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="Joint_2">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">2.356194</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="Joint_3">
      <command_interface name="position">
        <param name="min">-2.792527</param>
        <param name="max">0.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="Joint_4">
      <command_interface name="position">
        <param name="min">-2.094395</param>
        <param name="max">1.308997</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="Joint_5">
      <command_interface name="position">
        <param name="min">-2.75762</param>
        <param name="max">2.75762</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="Gripper">
      <command_interface name="position">
        <param name="min">-1.047198</param>
        <param name="max">0.261799</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_inner_back_joint">
      <param name="mimic">Gripper</param>
      <param name="multiplier">1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_outer_back_joint">
      <param name="mimic">Gripper</param>
      <param name="multiplier">1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_outer_back_joint">
      <param name="mimic">Gripper</param>
      <param name="multiplier">1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_inner_front_joint">
      <param name="mimic">Gripper</param>
      <param name="multiplier">1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_inner_front_joint">
      <param name="mimic">Gripper</param>
      <param name="multiplier">1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- AMIR アームリンクの Ignition Gazebo 摩擦設定
       Classic Gazebo: <mu1>/<mu2>/<kp>/<kd> を <gazebo reference> 直下に記述
       Ignition Gazebo: <collision><surface><friction><ode> 階層が必要 -->

  <gazebo reference="link0_1"><collision><surface><friction><ode>
    <mu>1.4</mu><mu2>1.4</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="link1_1"><collision><surface><friction><ode>
    <mu>1.4</mu><mu2>1.4</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="link2_1"><collision><surface><friction><ode>
    <mu>1.4</mu><mu2>1.4</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="link3_1"><collision><surface><friction><ode>
    <mu>1.4</mu><mu2>1.4</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="link4_1"><collision><surface><friction><ode>
    <mu>1.4</mu><mu2>1.4</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="gripper_base_1"><collision><surface><friction><ode>
    <mu>1.4</mu><mu2>1.4</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="inner_link_left_1"><collision><surface><friction><ode>
    <mu>2.0</mu><mu2>2.0</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="inner_link_right_1"><collision><surface><friction><ode>
    <mu>2.0</mu><mu2>2.0</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="outer_link_left_1"><collision><surface><friction><ode>
    <mu>2.0</mu><mu2>2.0</mu2>
  </ode></friction></surface></collision></gazebo>

  <gazebo reference="outer_link_right_1"><collision><surface><friction><ode>
    <mu>2.0</mu><mu2>2.0</mu2>
  </ode></friction></surface></collision></gazebo>

  <!-- グリッパー指: 高摩擦 + 接触剛性 (把持面) -->
  <gazebo reference="finger_left_1">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>3.0</mu>
            <mu2>3.0</mu2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e6</kp>
            <kd>1e3</kd>
            <max_vel>0.01</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="finger_right_1">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>3.0</mu>
            <mu2>3.0</mu2>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e6</kp>
            <kd>1e3</kd>
            <max_vel>0.01</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

</robot>
