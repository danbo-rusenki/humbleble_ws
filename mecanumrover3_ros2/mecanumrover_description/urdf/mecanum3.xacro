<?xml version="1.0" ?>
<robot name="mecanum3" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find mecanumrover_description)/urdf/materials.xacro" />
  <xacro:include filename="$(find mecanumrover_description)/urdf/mecanum3.gazebo" />
  <xacro:include filename="$(find mecanumrover_description)/urdf/mecanum3_ros2_control.xacro" />

  <xacro:include filename="$(find vs_rover_options_description)/urdf/lrf/tg30_mecanum3.xacro" />

  <!-- Arm link macro -->
  <xacro:macro name="mecanum_arm_link" params="name">
    <link name="${name}">
      <inertial>
        <origin xyz="0.001000 -0.054014 1.236051e-21"/>
        <mass value="0.5"/>
        <inertia ixx="7.442105e-04" iyy="2.141603e-04" izz="5.341336e-04" ixy="-4.944204e-21" ixz="1.236051e-21" iyz="1.089631e-04"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://mecanumrover_description/meshes/mecanum3/arms.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mecanumrover_description/meshes/mecanum3/arms.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>


  <!-- Wheel link macros
       Collision changed from mecanum STL mesh to cylinder for stable ODE contact.
       radius=0.076 matches the mecanum outer radius (barrel center 0.0666 + barrel radius 0.00956). -->
  <xacro:macro name="mecanum_wheel_link" params="name">
    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="0.88"/>
        <inertia ixx="7.666816e-04" iyy="7.666974e-04" izz="8.946765e-04" ixy="2.614197e-11" ixz="1.015151e-09" iyz="-2.439097e-09"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://mecanumrover_description/meshes/mecanum3/mecanum_wheel.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.076" length="0.05"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="mecanum_wheel_rev_link" params="name">
    <link name="${name}">
      <inertial>
        <origin xyz="0.000657 0 0.007742"/>
        <mass value="0.88"/>
        <inertia ixx="7.655818e-04" iyy="7.655769e-04" izz="8.900386e-04" ixy="-6.106217e-09" ixz="1.064093e-09" iyz="-2.991811e-09"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://mecanumrover_description/meshes/mecanum3/mecanum_wheel_rev.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.076" length="0.05"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>


  <!-- Wheel joint macro -->
  <xacro:macro name="mecanum_wheel_joint" params="name parent child xyz rpy axis_z">
    <joint name="${name}" type="continuous">
      <parent link="${parent}"/>
      <child link="${child}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 0 ${axis_z}"/>
      <limit effort="2500.0" velocity="20.0"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>
  </xacro:macro>


  <!-- Base -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.000129 -0.001817 0.110883"/>
      <mass value="20"/>
      <inertia ixx="1.346868e-01" iyy="4.468661e-02" izz="1.499091e-01" ixy="3.076527e-04" ixz="-2.931603e-05" iyz="2.763693e-05"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://mecanumrover_description/meshes/mecanum3/base_link.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://mecanumrover_description/meshes/mecanum3/base_link.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>


  <!-- Arms -->
  <xacro:mecanum_arm_link name="front_left_arm"/>
  <xacro:mecanum_arm_link name="front_right_arm"/>
  <xacro:mecanum_arm_link name="back_left_arm"/>
  <xacro:mecanum_arm_link name="back_right_arm"/>


  <!-- Suspension joints (fixed: eliminates oscillation that caused tipping) -->
  <joint name="front_left_suspension_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_arm"/>
    <origin xyz="-0.085 0.020 0.076" rpy="0 0 ${radians(180)}"/>
  </joint>

  <joint name="front_right_suspension_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_arm"/>
    <origin xyz="0.085 0.020 0.076" rpy="0 0 ${radians(180)}"/>
  </joint>

  <joint name="back_left_suspension_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_left_arm"/>
    <origin xyz="-0.085 -0.020 0.076" rpy="0 0 0"/>
  </joint>

  <joint name="back_right_suspension_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_right_arm"/>
    <origin xyz="0.085 -0.020 0.076" rpy="0 0 0"/>
  </joint>


  <!-- Wheels -->
  <xacro:mecanum_wheel_rev_link name="front_left_wheel_1"/>
  <xacro:mecanum_wheel_link     name="front_right_wheel_1"/>
  <xacro:mecanum_wheel_link     name="back_left_wheel_1"/>
  <xacro:mecanum_wheel_rev_link name="back_right_wheel_1"/>


  <!-- Wheel joints
       axis_z signs corrected so that +velocity → robot moves in +X (forward in base_footprint).
       base_joint is rotated Rz(-90°), making all wheel axes land on -Y in base_footprint
       with the original signs; negating them flips to +Y which gives forward motion. -->
  <xacro:mecanum_wheel_joint
    name="front_left_joint"
    parent="front_left_arm"
    child="front_left_wheel_1"
    xyz="0.03 -0.100 0"
    rpy="0 ${radians(-270)} 0"
    axis_z="1"/>

  <xacro:mecanum_wheel_joint
    name="front_right_joint"
    parent="front_right_arm"
    child="front_right_wheel_1"
    xyz="-0.03 -0.100 0"
    rpy="0 ${radians(-90)} 0"
    axis_z="-1"/>

  <xacro:mecanum_wheel_joint
    name="back_left_joint"
    parent="back_left_arm"
    child="back_left_wheel_1"
    xyz="-0.03 -0.100 0"
    rpy="0 ${radians(270)} 0"
    axis_z="1"/>

  <xacro:mecanum_wheel_joint
    name="back_right_joint"
    parent="back_right_arm"
    child="back_right_wheel_1"
    xyz="0.03 -0.100 0"
    rpy="0 ${radians(90)} 0"
    axis_z="-1"/>

</robot>
